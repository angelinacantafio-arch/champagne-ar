<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Modelli 3D — Champagne & Territoire</title>
<script src="https://unpkg.com/aframe@1.3.0/dist/aframe-master.min.js"></script>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body { background:#0a0a0a; font-family:Georgia,serif; color:#f5f0e8; }

  header {
    padding:1.5rem 2rem;
    border-bottom:1px solid rgba(184,134,11,0.2);
    display:flex; align-items:center; justify-content:space-between;
    background:#0f0c06;
  }
  header h1 { font-size:1.1rem; font-weight:400; }
  header h1 em { color:#d4a017; }
  .back { color:#d4a017; text-decoration:none; font-size:0.8rem; letter-spacing:0.1em; text-transform:uppercase; border:1px solid rgba(184,134,11,0.4); padding:0.35rem 0.8rem; }

  .tabs {
    display:flex; gap:0; border-bottom:1px solid rgba(184,134,11,0.2);
    background:#0f0c06;
  }
  .tab {
    flex:1; padding:1rem 0.5rem; text-align:center; cursor:pointer;
    font-size:0.82rem; letter-spacing:0.08em; color:#5a4a30;
    border-bottom:2px solid transparent; transition:all 0.2s;
  }
  .tab.active { color:#d4a017; border-bottom-color:#d4a017; background:rgba(184,134,11,0.04); }
  .tab:hover { color:#b8860b; }

  .scene-container { display:none; width:100%; height:calc(100vh - 130px); position:relative; }
  .scene-container.active { display:block; }

  a-scene { width:100% !important; height:100% !important; }

  .info-panel {
    position:absolute; bottom:0; left:0; right:0;
    background:linear-gradient(to top, rgba(0,0,0,0.9) 60%, transparent);
    padding:1.5rem 2rem 2rem;
    pointer-events:none;
  }
  .info-name { font-size:1.3rem; font-weight:400; margin-bottom:0.4rem; }
  .info-name em { color:#d4a017; font-style:italic; }
  .info-stats {
    display:flex; gap:2rem; flex-wrap:wrap; margin-top:0.8rem;
  }
  .stat { }
  .stat-value { display:block; font-size:1.1rem; color:#d4a017; font-style:italic; }
  .stat-label { font-size:0.65rem; letter-spacing:0.2em; text-transform:uppercase; color:#5a4a30; }

  .hint {
    position:absolute; top:1rem; left:50%; transform:translateX(-50%);
    font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase;
    color:rgba(184,134,11,0.6); background:rgba(0,0,0,0.5);
    padding:0.3rem 0.8rem; border:1px solid rgba(184,134,11,0.2);
    pointer-events:none; white-space:nowrap;
  }
</style>
</head>
<body>

<header>
  <h1>Champagne &amp; <em>Territoire</em> — Modelli 3D</h1>
  <a href="index.html" class="back">← Indietro</a>
</header>

<div class="tabs">
  <div class="tab active" onclick="showModel(0)">🍾 Champagne</div>
  <div class="tab"        onclick="showModel(1)">🌾 Blé</div>
  <div class="tab"        onclick="showModel(2)">🧀 Chaource</div>
</div>

<!-- ══ MODELLO 1: Bottiglia Champagne ══ -->
<div class="scene-container active" id="scene-0">
  <span class="hint">🖱 Trascina per ruotare · Scroll per zoom</span>
  <a-scene embedded background="color:#0a0a0a" renderer="antialias:true" vr-mode-ui="enabled:false" loading-screen="enabled:false">
    <a-entity light="type:ambient;color:#ffffff;intensity:0.4"></a-entity>
    <a-entity light="type:directional;color:#fff8e7;intensity:0.8" position="1 2 1"></a-entity>
    <a-entity light="type:directional;color:#d4a017;intensity:0.3" position="-2 1 -1"></a-entity>

    <a-entity id="champagne-group"
      animation="property:rotation; to:0 360 0; loop:true; dur:12000; easing:linear"
      position="0 0 -2.5">

      <!-- Corpo bottiglia -->
      <a-cylinder position="0 0 0"    radius="0.22" height="1.6"  color="#1a4010" metalness="0.1" roughness="0.3"></a-cylinder>
      <!-- Gradiente base -->
      <a-cylinder position="0 -0.85 0" radius="0.2"  height="0.1"  color="#0f2808"></a-cylinder>
      <!-- Concavità base -->
      <a-sphere   position="0 -0.9 0"  radius="0.1"  color="#0d2006" scale="1 0.4 1"></a-sphere>
      <!-- Spalla -->
      <a-sphere   position="0 0.9 0"   radius="0.19" color="#1a4010" scale="1 0.7 1"></a-sphere>
      <!-- Collo lungo -->
      <a-cylinder position="0 1.25 0"  radius="0.09" height="0.6"  color="#1a4010"></a-cylinder>
      <!-- Labbro collo -->
      <a-cylinder position="0 1.58 0"  radius="0.1"  height="0.06" color="#1a4010"></a-cylinder>
      <!-- Gabbietta dorata -->
      <a-cylinder position="0 1.62 0"  radius="0.11" height="0.1"  color="#c8a200" metalness="0.8" roughness="0.2"></a-cylinder>
      <!-- Tappo -->
      <a-cylinder position="0 1.7 0"   radius="0.1"  height="0.08" color="#e8e8e8" metalness="0.6"></a-cylinder>
      <!-- Etichetta bianca -->
      <a-cylinder position="0 0.05 0"  radius="0.225" height="0.55" color="#fdf8ec" metalness="0" roughness="0.9"></a-cylinder>
      <!-- Testo etichetta -->
      <a-text value="CHAMPAGNE" position="0 0.22 0.226" align="center" color="#8b0000" width="1.2" rotation="0 0 0"></a-text>
      <a-text value="AOC" position="0 0.02 0.226" align="center" color="#c8a200" width="0.8"></a-text>
      <a-text value="Brut" position="0 -0.18 0.226" align="center" color="#333" width="0.6"></a-text>
    </a-entity>

    <a-entity camera look-controls orbit-controls="target:0 0 -2.5; minDistance:1; maxDistance:6; initialPosition:0 0.5 2"></a-entity>
  </a-scene>

  <div class="info-panel">
    <div class="info-name">Champagne <em>AOC</em></div>
    <div style="font-size:0.8rem;color:#7a6a50;margin-top:0.2rem;">Vino spumante — Appellation d'Origine Contrôlée</div>
    <div class="info-stats">
      <div class="stat"><span class="stat-value">4,9 Mld €</span><span class="stat-label">Export annuo</span></div>
      <div class="stat"><span class="stat-value">34.000 ha</span><span class="stat-label">Vigneti</span></div>
      <div class="stat"><span class="stat-value">16.000</span><span class="stat-label">Viticoltori</span></div>
      <div class="stat"><span class="stat-value">300 M bottiglie</span><span class="stat-label">Produzione/anno</span></div>
    </div>
  </div>
</div>

<!-- ══ MODELLO 2: Spiga di grano ══ -->
<div class="scene-container" id="scene-1">
  <span class="hint">🖱 Trascina per ruotare · Scroll per zoom</span>
  <a-scene embedded background="color:#0a0a0a" renderer="antialias:true" vr-mode-ui="enabled:false" loading-screen="enabled:false">
    <a-entity light="type:ambient;color:#fff8d0;intensity:0.5"></a-entity>
    <a-entity light="type:directional;color:#fff8d0;intensity:0.9" position="1 3 1"></a-entity>
    <a-entity light="type:directional;color:#d4a017;intensity:0.4" position="-1 1 -1"></a-entity>

    <a-entity
      animation="property:rotation; to:0 360 0; loop:true; dur:14000; easing:linear"
      position="0 -0.5 -2.5">

      <!-- Stelo principale -->
      <a-cylinder position="0 0.7 0" radius="0.04" height="1.4" color="#8b6914"></a-cylinder>
      <!-- Nodo stelo -->
      <a-sphere position="0 0.3 0" radius="0.06" color="#7a5c10"></a-sphere>

      <!-- Foglia sinistra bassa -->
      <a-plane position="-0.25 0.4 0" width="0.5" height="0.08" color="#6a9a20" rotation="0 0 25"></a-plane>
      <!-- Foglia destra -->
      <a-plane position="0.25 0.6 0"  width="0.5" height="0.08" color="#6a9a20" rotation="0 0 -20"></a-plane>

      <!-- Spiga: 8 coppie di chicchi + punta -->
      <a-sphere position=" 0.09 1.12 0" radius="0.09" color="#e8c840"></a-sphere>
      <a-sphere position="-0.09 1.18 0" radius="0.09" color="#e8c840"></a-sphere>
      <a-sphere position=" 0.09 1.28 0" radius="0.085" color="#e0c038"></a-sphere>
      <a-sphere position="-0.09 1.34 0" radius="0.085" color="#e0c038"></a-sphere>
      <a-sphere position=" 0.08 1.43 0" radius="0.078" color="#d8b830"></a-sphere>
      <a-sphere position="-0.08 1.48 0" radius="0.078" color="#d8b830"></a-sphere>
      <a-sphere position=" 0.07 1.56 0" radius="0.07"  color="#d0b028"></a-sphere>
      <a-sphere position="-0.07 1.61 0" radius="0.07"  color="#d0b028"></a-sphere>
      <a-sphere position=" 0.05 1.68 0" radius="0.062" color="#c8a820"></a-sphere>
      <a-sphere position="-0.05 1.73 0" radius="0.062" color="#c8a820"></a-sphere>
      <a-sphere position="    0 1.79 0" radius="0.05"  color="#c0a018"></a-sphere>

      <!-- Reste (barbe) -->
      <a-cylinder position=" 0.09 1.85 0" radius="0.005" height="0.3" color="#a08010" rotation="0 0 15"></a-cylinder>
      <a-cylinder position="-0.09 1.85 0" radius="0.005" height="0.3" color="#a08010" rotation="0 0 -15"></a-cylinder>
      <a-cylinder position="    0 1.90 0" radius="0.005" height="0.35" color="#a08010"></a-cylinder>
    </a-entity>

    <a-entity camera look-controls orbit-controls="target:0 0 -2.5; minDistance:1; maxDistance:6; initialPosition:0 0.5 2"></a-entity>
  </a-scene>

  <div class="info-panel">
    <div class="info-name">Blé de <em>Champagne</em></div>
    <div style="font-size:0.8rem;color:#7a6a50;margin-top:0.2rem;">Frumento tenero — Champagne Crayeuse</div>
    <div class="info-stats">
      <div class="stat"><span class="stat-value">650.000 t</span><span class="stat-label">Produzione/anno</span></div>
      <div class="stat"><span class="stat-value">1° posto</span><span class="stat-label">In Francia per resa</span></div>
      <div class="stat"><span class="stat-value">85 q/ha</span><span class="stat-label">Resa media</span></div>
      <div class="stat"><span class="stat-value">Pianura cretacea</span><span class="stat-label">Terreno</span></div>
    </div>
  </div>
</div>

<!-- ══ MODELLO 3: Chaource ══ -->
<div class="scene-container" id="scene-2">
  <span class="hint">🖱 Trascina per ruotare · Scroll per zoom</span>
  <a-scene embedded background="color:#0a0a0a" renderer="antialias:true" vr-mode-ui="enabled:false" loading-screen="enabled:false">
    <a-entity light="type:ambient;color:#fff5e0;intensity:0.5"></a-entity>
    <a-entity light="type:directional;color:#fff5e0;intensity:1.0" position="2 3 2"></a-entity>
    <a-entity light="type:directional;color:#d4a017;intensity:0.3" position="-2 1 -1"></a-entity>

    <a-entity
      animation="property:rotation; to:0 360 0; loop:true; dur:13000; easing:linear"
      position="0 0 -2.5">

      <!-- Formaggio intero (disco) -->
      <a-cylinder position="0 0 0" radius="0.55" height="0.35" color="#f0e0b0" roughness="0.8"></a-cylinder>
      <!-- Crosta superiore più chiara con muffa bianca -->
      <a-cylinder position="0 0.18 0"  radius="0.552" height="0.02" color="#ede0c0" roughness="1"></a-cylinder>
      <!-- Crosta laterale (toro) -->
      <a-torus position="0 0 0" radius="0.55" radius-tubular="0.03" color="#d4c090" roughness="0.9"></a-torus>

      <!-- Fetta staccata — corpo -->
      <a-cylinder position="0.75 0 0" radius="0.26" height="0.35" color="#f5e8c0" roughness="0.7"></a-cylinder>
      <!-- Fetta — sezione interna (piano di taglio) -->
      <a-plane position="0.5 0 0" width="0.52" height="0.35" color="#faf0d0" rotation="0 90 0"></a-plane>
      <!-- Fetta — crosta superiore -->
      <a-cylinder position="0.75 0.18 0" radius="0.262" height="0.018" color="#ece0b8"></a-cylinder>

      <!-- Piccoli occhi interni pasta (solo sulla fetta) -->
      <a-sphere position="0.52 0.05 0.1"  radius="0.02" color="#e8dab0"></a-sphere>
      <a-sphere position="0.52 -0.04 -0.08" radius="0.018" color="#e8dab0"></a-sphere>
      <a-sphere position="0.52 0.08 -0.05" radius="0.015" color="#e8dab0"></a-sphere>
    </a-entity>

    <a-entity camera look-controls orbit-controls="target:0 0 -2.5; minDistance:1; maxDistance:6; initialPosition:0 0.8 2.5"></a-entity>
  </a-scene>

  <div class="info-panel">
    <div class="info-name">Chaource <em>AOP</em></div>
    <div style="font-size:0.8rem;color:#7a6a50;margin-top:0.2rem;">Formaggio a pasta molle — Appellation d'Origine Protégée</div>
    <div class="info-stats">
      <div class="stat"><span class="stat-value">~800 t</span><span class="stat-label">Produzione/anno</span></div>
      <div class="stat"><span class="stat-value">AOP Europa</span><span class="stat-label">Certificazione</span></div>
      <div class="stat"><span class="stat-value">dal XIV sec.</span><span class="stat-label">Tradizione storica</span></div>
      <div class="stat"><span class="stat-value">Pasta molle</span><span class="stat-label">Crosta fiorita</span></div>
    </div>
  </div>
</div>

<script>
  function showModel(idx) {
    document.querySelectorAll('.tab').forEach((t,i) => t.classList.toggle('active', i===idx));
    document.querySelectorAll('.scene-container').forEach((s,i) => s.classList.toggle('active', i===idx));
  }
</script>
</body>
</html>
