  body {
    font-family:Georgia,serif; background:white;
    display:flex; flex-direction:column; align-items:center;
    justify-content:center; min-height:100vh; gap:7mm; padding:8mm;
    text-align:center;
  }
  h1  { font-size:18pt; color:#1a3a08; letter-spacing:.06em; }
  .sub { font-size:9.5pt; color:#666; }
  .wrap { border:6px solid black; padding:5mm; background:white; display:inline-block; }
  .badge { background:#1a3a08; color:white; font-size:7.5pt; letter-spacing:.2em; padding:2mm 7mm; text-transform:uppercase; }
